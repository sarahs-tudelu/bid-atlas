# Free public key generated from the Account Details page on SAM.gov.
SAM_API_KEY=

# Long random token protecting POST /api/internal/ingest.
INGEST_TOKEN=

# Optional free production key for higher-confidence Data.gov v4 access.
# Without it, discovery uses the bounded public catalog-search fallback.
DATA_GOV_API_KEY=

# Optional professional-contact enrichment. Personal email, phone, and waterfall
# enrichment are disabled by the adapter, and every request must confirm credit use.
APOLLO_API_KEY=
APOLLO_ENRICHMENT_ENABLED=false

# Required before users can save personal provider credentials. Generate one
# random 32-byte value and store its standard base64 representation as a hosted
# secret. Rotating this value requires a credential re-encryption migration.
BIDATLAS_CREDENTIALS_MASTER_KEY=

# Optional identity for localhost development only. This is ignored unless the
# app is running in development mode on a loopback host. Do not configure it in
# a hosted environment.
BIDATLAS_DEV_USER_EMAIL=

# Long random token for approved internal enrichment calls outside workspace auth.
BIDATLAS_INTERNAL_TOKEN=

# Active AWS catalog settings. Leave the bucket unset for local development so
# FastAPI uses data-export/current-projects.json directly.
BIDATLAS_CATALOG_BUCKET=
BIDATLAS_CATALOG_KEY=current-projects.json
BIDATLAS_CATALOG_REFRESH_SECONDS=300
