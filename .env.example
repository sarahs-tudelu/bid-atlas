# Local FastAPI runtime
BIDATLAS_ENVIRONMENT=development
BIDATLAS_DATA_DIR=data-export
BIDATLAS_CATALOG_BUCKET=
BIDATLAS_CATALOG_KEY=current-projects.json
BIDATLAS_CATALOG_REFRESH_SECONDS=300
BIDATLAS_WORKSPACE_TABLE=
BIDATLAS_DOCUMENTS_BUCKET=
BIDATLAS_CORS_ORIGINS=http://localhost:5173
BIDATLAS_PUBLIC_URL=http://localhost:5173

# Local Google OAuth web client. Production reads equivalent SecureStrings from SSM.
BIDATLAS_GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
BIDATLAS_GOOGLE_SCOPES="openid email profile https://www.googleapis.com/auth/gmail.send https://www.googleapis.com/auth/gmail.readonly"
BIDATLAS_GOOGLE_CLIENT_ID=
BIDATLAS_GOOGLE_CLIENT_SECRET=
BIDATLAS_SESSION_SECRET=
BIDATLAS_ANTHROPIC_API_KEY=
BIDATLAS_ANTHROPIC_MODEL=claude-sonnet-4-6
BIDATLAS_INSTANTLY_API_TOKEN=
BIDATLAS_MARKETING_SENDER=outreach@tudelugroup.com

# Production-only SSM parameter names. CDK sets these on Lambda.
BIDATLAS_GOOGLE_CLIENT_ID_PARAMETER=/BidAtlas/google-client-id
BIDATLAS_GOOGLE_CLIENT_SECRET_PARAMETER=/BidAtlas/google-client-secret
BIDATLAS_SESSION_SECRET_PARAMETER=/BidAtlas/session-secret
BIDATLAS_SAM_API_KEY_PARAMETER=/BidAtlas/sam-api-key
BIDATLAS_ANTHROPIC_API_KEY_PARAMETER=/BidAtlas/anthropic-api-key
BIDATLAS_INSTANTLY_API_TOKEN_PARAMETER=/tudelu-marketing/INSTANTLY_API_TOKEN

# The official SAM.gov Opportunities API key may be supplied directly only for a local refresh.
SAM_API_KEY=
